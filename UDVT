def relic_density(m_sigma_gev, lambda_ph, T_freeze_ratio=20)
    Calculate Omega h^2 for sigma dark matter.
    Parameters:
    m_sigma_gev : mass in GeV
    lambda_ph : Higgs-portal coupling
    T_freeze_ratio : x_f = m/T_f (default 20)
    
    Returns:
    omega_h2 : relic density parameter
    cross_section_cm3s : annihilation cross section in cm^3/s
    """
    # Cross section in GeV^{-2}
    sigma_v_gev2 = (lambda_ph**2) / (16 * np.pi * m_sigma_gev**2)
    # Convert to cm^3/s (1 GeV^{-2} = 1.16e-17 cm^2, times c=3e10 cm/s)
    sigma_v_cm3s = sigma_v_gev2 * 1.16e-17 * 3e10
    # Relic density formula (Steigman et al.)
    omega_h2 = 0.1 / (sigma_v_cm3s / 3e-26)  # normalized to 3e-26 cm^3/s
    return omega_h2, sigma_v_cm3s

