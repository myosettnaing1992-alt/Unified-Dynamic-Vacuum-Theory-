def alpha_z(z, zeta=0.0012):
    """Fine-structure constant evolution with redshift."""
    return 1.0 + zeta * np.log(1 + z)

def thomson_cross_section(z, zeta=0.0012):
    """Thomson cross section scaling with alpha^2."""
    return (alpha_z(z, zeta))**2

def damping_tail_modification(l, zeta=0.0012):
    """Simple model for CMB damping tail suppression.
    
    l : multipole moment
    Returns: relative change in C_l TT power spectrum
    """
    # Damping scale suppression factor (qualitative)
    # More precise calculation requires CAMB/CLASS
    return np.exp(- (l/2000)**2 * zeta * 10)

