def boltzmann_ode(Y, x, lambda_eff, g_star=100):
    """
    ODE for dark matter yield Y = n/s.
    dY/dx = - (lambda_eff / x^2) * (Y^2 - Y_eq^2)
    """
    Y_eq = 0.145 * (g_star/100)**0.5 * x**1.5 * np.exp(-x)
    dYdx = - (lambda_eff / x**2) * (Y**2 - Y_eq**2)
    return dYdx

def solve_relic_density(m_gev, sigma_v_cm3s, x_start=1, x_end=1000):
    """
    Solve Boltzmann equation to get final abundance.
    """
    # Convert cross section to dimensionless lambda_eff
    # lambda_eff = (s0 * sigma_v) / (H(m) * x_f) ... simplified
    # For demonstration, use an approximate scaling
    lambda_eff = 1e-9 / (sigma_v_cm3s / 3e-26)
    x_grid = np.logspace(np.log10(x_start), np.log10(x_end), 200)
    Y0 = [1e-8]  # initial guess
    sol = odeint(boltzmann_ode, Y0, x_grid, args=(lambda_eff,))
    return x_grid, sol[:,0]

