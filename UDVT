def fermion_masses(N_values, vev_gev=246.22, kappa0=2.1e-6, alpha=5.33, color_factor=1.0):
    """
    Compute fermion masses from winding number.
    
    Parameters:
    N_values : list of winding numbers
    vev_gev : vacuum expectation value in GeV
    kappa0 : base coefficient (from electron mass)
    alpha : exponential scaling constant
    color_factor : 1 for leptons, 4/3 for quarks
    
    Returns:
    masses_gev : array of masses in GeV
    """
    masses = kappa0 * vev_gev * np.exp(alpha * np.array(N_values)) * color_factor
    return masses

